{
  "description": "Other mappings (Windows-like, with Ctrl/Cmd swapped in System Preferences)",
  "manipulators": [
    {
      "from": {
        "key_code": "delete_forward",
        "modifiers": {
          "mandatory": ["control", "option"],
          "optional": ["any"]
        }
      },
      "to": [{ "shell_command": "open -a 'Activity Monitor'" }],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "keypad_period",
        "modifiers": {
          "mandatory": ["control", "option"],
          "optional": ["any"]
        }
      },
      "to": [{ "shell_command": "open -a 'Activity Monitor'" }],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "escape",
        "modifiers": {
          "mandatory": ["control", "shift"],
          "optional": ["any"]
        }
      },
      "to": [{ "shell_command": "open -a 'Activity Monitor'" }],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "spacebar",
        "modifiers": {
          "mandatory": ["option"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "spacebar",
          "modifiers": ["control"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.apple\\.finder$",
            "^com\\.apple\\.Desktop$"
          ],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "delete_forward",
        "modifiers": { "optional": ["any"] }
      },
      "to": [
        {
          "key_code": "delete_or_backspace",
          "modifiers": ["control"]
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "home",
        "modifiers": { "optional": ["any"] }
      },
      "to": [
        {
          "key_code": "left_arrow",
          "modifiers": ["control"]
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "end",
        "modifiers": { "optional": ["any"] }
      },
      "to": [
        {
          "key_code": "right_arrow",
          "modifiers": ["control"]
        }
      ],
      "type": "basic"
    }
  ]
}