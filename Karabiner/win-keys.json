{
  "description": "Win key combos (Windows-like, with Ctrl/Cmd swapped in System Preferences)",
  "manipulators": [
    {
      "from": {
        "key_code": "l",
        "modifiers": {
          "mandatory": ["command"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "q",
          "modifiers": ["control", "command"]
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "r",
        "modifiers": {
          "mandatory": ["command"],
          "optional": ["any"]
        }
      },
      "to": [{ "shell_command": "open -a 'Terminal'" }],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "e",
        "modifiers": {
          "mandatory": ["command"],
          "optional": ["any"]
        }
      },
      "to": [{ "shell_command": "open -a 'Finder'" }],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "d",
        "modifiers": {
          "mandatory": ["command"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "f11",
          "modifiers": ["fn"]
        }
      ],
      "type": "basic"
    }
  ]
}