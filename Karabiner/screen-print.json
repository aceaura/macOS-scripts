{
  "description": "Screen print (Windows-like, with Ctrl/Cmd swapped in System Preferences)",
  "manipulators": [
    {
      "from": {
        "key_code": "a",
        "modifiers": {
          "mandatory": ["control", "option"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "4",
          "modifiers": ["control", "shift"]
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "a",
        "modifiers": {
          "mandatory": ["option"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "4",
          "modifiers": ["control", "command", "shift"]
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "print_screen",
        "modifiers": {
          "mandatory": ["control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "3",
          "modifiers": ["control", "shift"]
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "print_screen",
        "modifiers": { "optional": ["any"] }
      },
      "to": [
        {
          "key_code": "3",
          "modifiers": ["control", "command", "shift"]
        }
      ],
      "type": "basic"
    }
  ]
}
